{
  "name": "habit-tracker-backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "tsc",
    "db:migrate": "node-pg-migrate up --migrations-dir migrations",
    "db:migrate:down": "node-pg-migrate down --migrations-dir migrations",
    "db:migrate:create": "node-pg-migrate create --migrations-dir migrations",
    "db:check": "tsx src/jobs/runDbHealthCheck.ts",
    "start": "node dist/server.js",
    "reminders:run": "tsx src/jobs/runReminderCheckOnce.ts",
    "test": "node --test --import tsx src/**/*.test.ts"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "google-auth-library": "^10.9.0",
    "jsonwebtoken": "^9.0.3",
    "node-pg-migrate": "^9.0.0",
    "nodemailer": "^9.0.3",
    "pg": "^8.16.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.12.3",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2"
  }
}
