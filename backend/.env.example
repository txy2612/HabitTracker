PORT=4000
LOG_LEVEL=info
LOG_PRETTY=true
# Supabase session pooler for a persistent Express backend.
# Copy the connection string from Supabase Dashboard > Connect and URL-encode the password.
DATABASE_URL=postgresql://postgres.PROJECT_REF:URL_ENCODED_PASSWORD@REGION.pooler.supabase.com:5432/postgres?sslmode=require
CORS_ORIGIN=http://localhost:5173
# HTTP sends web requests
# SMTP sends email
# These are private, so they are kept outside the source code.
# Email reminders
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Habit Tracker <reminders@example.com>"
JWT_SECRET=replace-with-a-long-random-secret
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
