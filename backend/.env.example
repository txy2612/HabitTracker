PORT=4000
LOG_LEVEL=info
LOG_PRETTY=true
DATABASE_URL=postgres://postgres:postgres@localhost:5432/habit_tracker
CORS_ORIGIN=http://localhost:5173
# HTTP sends web requests
# SMTP sends email
# These are private, so they are kept outside the source code.
# Email reminders
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Habit Tracker <reminders@example.com>"
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com